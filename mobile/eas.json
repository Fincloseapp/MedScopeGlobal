{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "runtimeVersion": {
    "policy": "appVersion"
  },
  "update": {
    "url": "https://u.expo.dev/REPLACE_WITH_EAS_PROJECT_ID"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
