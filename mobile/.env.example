# MedScope Academy Mobile — environment placeholders (do not commit secrets)

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Google OAuth (Supabase Auth → Google provider)
# iOS: create OAuth client in Google Cloud Console (iOS type)
# Android: create OAuth client with package com.medscopeglobal.academy + SHA-1
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=REPLACE_IOS_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=REPLACE_ANDROID_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=REPLACE_WEB_CLIENT_ID.apps.googleusercontent.com

# Deep link scheme (must match app.json)
# medscope-academy://auth/callback
