{
  "expo": {
    "name": "MedScope Academy",
    "slug": "medscope-academy",
    "version": "0.1.0",
    "scheme": "medscope-academy",
    "platforms": ["ios", "android"],
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.medscopeglobal.academy",
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["medscope-academy"]
          }
        ]
      }
    },
    "android": {
      "package": "com.medscopeglobal.academy",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "medscope-academy"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": ["expo-router"],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      },
      "googleOAuth": {
        "iosClientId": "REPLACE_IOS_CLIENT_ID.apps.googleusercontent.com",
        "androidClientId": "REPLACE_ANDROID_CLIENT_ID.apps.googleusercontent.com",
        "webClientId": "REPLACE_WEB_CLIENT_ID.apps.googleusercontent.com"
      },
      "router": {
        "origin": "https://medscopeglobal.com"
      }
    }
  }
}
