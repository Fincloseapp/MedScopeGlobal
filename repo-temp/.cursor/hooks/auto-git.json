{
  "trigger": "onSave",
  "action": "node scripts/auto-git-commit-push.js",
  "debounceMs": 8000,
  "branch": "main",
  "remote": "origin",
  "deploy": {
    "provider": "vercel",
    "domain": "https://medscopeglobal.com"
  },
  "retry": {
    "pushAttempts": 3,
    "pushDelaySeconds": 10
  },
  "log": ".cursor/hooks/auto-git.log"
}
