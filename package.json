{
  "name": "medscopeglobal",
  "version": "0.1.0",
  "description": "MedScopeGlobal medical knowledge-sharing platform",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:vercel": "node scripts/vercel-build.mjs && next build",
    "setup:production": "node scripts/setup-production.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.mjs",
    "postinstall": "prisma generate",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fincloseapp/MedScopeGlobal.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Fincloseapp/MedScopeGlobal/issues"
  },
  "homepage": "https://github.com/Fincloseapp/MedScopeGlobal#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.55.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "next": "^16.2.6",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "private": true,
  "type": "module",
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "overrides": {
    "postcss": "8.5.15",
    "@hono/node-server": "1.19.14"
  }
}
