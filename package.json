{
  "name": "med-scope-global",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "next dev",
    "build": "node -e \"const { execSync } = require('child_process'); if (process.platform === 'win32') { execSync('powershell -ExecutionPolicy Bypass -File ./scripts/build-win.ps1', { stdio: 'inherit' }); } else { execSync('next build', { stdio: 'inherit' }); }\"",
    "build:win": "powershell -ExecutionPolicy Bypass -File ./scripts/build-win.ps1",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/test-v18-placeholder.mjs",
    "test:v18": "node scripts/run-v18-e2e.mjs",
    "load:v18": "node loadtests/v18/run-all.mjs",
    "verify-v18": "node scripts/verify-v18.mjs",
    "env:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-env.ps1",
    "env:validate": "node scripts/validate-production-env.mjs",
    "env:verify": "node scripts/verify-env.mjs",
    "env:diff": "node scripts/diff-vercel-env.mjs",
    "db:setup": "node scripts/apply-migrations.mjs",
    "db:migrate": "node scripts/apply-migrations.mjs",
    "db:apply-translations": "node scripts/apply-article-translations-table.mjs",
    "db:apply-pg": "node scripts/apply-migration-pg.mjs",
    "db:verify": "node scripts/verify-supabase.mjs",
    "content:bootstrap": "node scripts/seed-categories.mjs && node scripts/run-ingestion.mjs",
    "content:seed": "node scripts/seed-categories.mjs",
    "content:ingest": "node scripts/run-ingestion.mjs",
    "production:bootstrap": "node scripts/production-bootstrap.mjs",
    "production:check": "node scripts/publish-checklist.mjs",
    "production:finalize": "node scripts/production-finalize.mjs",
    "production:validate": "node scripts/validate-production-env.mjs && npm run db:verify",
    "route:validate": "npx tsx scripts/validate-routes.ts",
    "env:repair-openai": "node scripts/repair-openai-env.mjs",
    "vercel:env": "node scripts/sync-vercel-env.mjs",
    "deploy:vercel": "node scripts/deploy-vercel-production.mjs",
    "verify-v6": "node scripts/verify-v6-api-routes.mjs",
    "verify-v17": "node scripts/verify-v17-skeleton.mjs && node scripts/verify-acp.mjs && node scripts/verify-clinical-safety.mjs",
    "predeploy": "node scripts/run-predeploy-gates.mjs",
    "healthcheck-local": "node node_modules/tsx/dist/cli.mjs scripts/deploy/health-runner.ts",
    "deploy:v17": "node scripts/deploy/vercel_production.mjs",
    "rollback:v17": "node scripts/deploy/vercel_rollback.mjs",
    "commit:v17": "node scripts/commit-v17-pipeline.mjs",
    "dns:cloudflare": "node scripts/cloudflare-point-vercel.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/react-query": "^5.59.0",
    "@tiptap/pm": "^2.9.1",
    "@tiptap/react": "^2.9.1",
    "@tiptap/starter-kit": "^2.9.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.454.0",
    "mammoth": "^1.12.0",
    "next": "^15.2.6",
    "next-themes": "^0.4.6",
    "pdf-parse": "^1.1.4",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "stripe": "^17.7.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^6.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^20.17.6",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.2.6",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3"
  }
}
