{
  "name": "medscope-auto-git-hook",
  "version": 1,
  "description": "Cursor automation — auto commit + push + Vercel deploy on file save",
  "trigger": "onFileSave",
  "action": "node scripts/auto-git-commit-push.js",
  "debounceMs": 8000,
  "branch": "main",
  "remote": "origin",
  "cursorHook": {
    "file": ".cursor/hooks.json",
    "event": "afterFileEdit",
    "command": "node .scripts/hooks/auto-git-save.js",
    "sessionStartCommand": "node .scripts/hooks/auto-git-flush.js"
  },
  "safety": {
    "skipEmptyCommit": true,
    "stopOnConflict": true,
    "offlineQueuePush": true,
    "pushRetries": 3,
    "pushRetryDelaySeconds": 10
  },
  "deploy": {
    "provider": "vercel",
    "productionBranch": "main",
    "domain": "https://medscopeglobal.com"
  },
  "log": ".scripts/logs/auto-git.log"
}
