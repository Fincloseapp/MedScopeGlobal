{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "INGESTION_LOCALE": "cs",
    "DEFAULT_SITE_LOCALE": "cs",
    "OPENAI_MODEL": "gpt-4o-mini",
    "PUBLIC_WRITER_LIMIT": "4",
    "INGEST_MAX_ARTICLES": "80"
  },
  
  "crons": [
    {
      "path": "/api/cron/ingest",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/v4c-drugs",
      "schedule": "15 6 * * *"
    },
    {
      "path": "/api/cron/v4c-daily",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/newsletter-generate",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/medical-ai-fetch",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/daily-pubmed-update",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/daily-regulatory-update",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/hourly-pubmed-monitor",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/daily-regulatory-monitor",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/daily-autopublish",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/weekly-trend-analysis",
      "schedule": "0 13 * * 1"
    },
    {
      "path": "/api/cron/monthly-guideline-update",
      "schedule": "0 14 1 * *"
    },
    {
      "path": "/api/cron/v19-daily-briefs",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/v19-nzip-index",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/v19-nzip-refresh",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron/v24-ultra",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/v25-enterprise",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/v25-nav-monitor",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/v25-universities",
      "schedule": "30 17 * * *"
    },
    {
      "path": "/api/cron/v25-images",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/public-articles",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/marketing",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/v26-rewrite",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/v26-autonomous",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/cron/academy-daily",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/academy-weekly",
      "schedule": "0 21 * * 0"
    },
    {
      "path": "/api/cron/academy-monthly",
      "schedule": "0 22 1 * *"
    },
    {
      "path": "/api/cron/academy-quality-weekly",
      "schedule": "0 23 * * 0"
    },
    {
      "path": "/api/cron/public-osveta-daily",
      "schedule": "0 7 * * *"
    }
  ],
  
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],

  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.medscopeglobal.com" }],
      "destination": "https://medscopeglobal.com/:path*",
      "permanent": true
    }
  ]
}

