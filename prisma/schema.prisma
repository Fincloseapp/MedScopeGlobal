generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  DOCTOR
  STUDENT
  SCIENTIST
  PARTNER
}

enum PortalRole {
  READER
  EXPERT
  ADMIN
}

enum VerificationStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EventFormat {
  ONLINE
  HYBRID
  IN_PERSON
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Article {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  summary        String
  content        String
  author         String
  source         String
  sourceUrl      String?
  region         String?
  specialization String?
  audience       String   @default("laik-student")
  publishedAt    DateTime
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@index([publishedAt])
  @@index([specialization])
  @@index([audience])
}

model PortalUser {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  name               String
  role               PortalRole         @default(READER)
  verificationStatus VerificationStatus @default(NOT_REQUIRED)
  institution        String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  articles           PortalArticle[]
  ratings            ArticleRating[]
  savedArticles      SavedArticle[]
}

model PortalArticle {
  id                      String        @id @default(cuid())
  slug                    String        @unique
  title                   String
  summary                 String
  sections                Json
  clinicalSignificance    String
  practiceRecommendations String
  citations               Json
  tags                    String[]
  icdCodes                String[]
  specialization          String
  status                  ArticleStatus @default(DRAFT)
  authorId                String
  author                  PortalUser    @relation(fields: [authorId], references: [id])
  authorName              String
  publishedAt             DateTime?
  validatedById           String?
  validatedAt             DateTime?
  readingTime             Int           @default(5)
  ratingSum               Int           @default(0)
  ratingCount             Int           @default(0)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  ratings                 ArticleRating[]
  savedBy                 SavedArticle[]

  @@index([status])
  @@index([specialization])
  @@index([publishedAt])
  @@index([authorId])
}

model ArticleRating {
  userId    String
  articleId String
  score     Int
  createdAt DateTime      @default(now())
  user      PortalUser    @relation(fields: [userId], references: [id])
  article   PortalArticle @relation(fields: [articleId], references: [id])

  @@id([userId, articleId])
}

model SavedArticle {
  userId    String
  articleId String
  savedAt   DateTime      @default(now())
  user      PortalUser    @relation(fields: [userId], references: [id])
  article   PortalArticle @relation(fields: [articleId], references: [id])

  @@id([userId, articleId])
}

model Event {
  id              String         @id @default(cuid())
  slug            String         @unique
  title           String
  description     String
  region          String
  format          EventFormat
  specialization  String
  startsAt        DateTime
  endsAt          DateTime
  timezone        String         @default("Europe/Prague")
  organizer       String
  venue           String?
  registrationUrl String?
  approvalStatus  ApprovalStatus @default(APPROVED)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([startsAt])
  @@index([region])
  @@index([format])
  @@index([specialization])
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  role        UserRole
  preferences Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactSubmission {
  id           String   @id @default(cuid())
  name         String
  email        String
  organization String?
  role         UserRole?
  topic        String
  message      String
  targetEmail  String
  leadSource   String?
  leadQuality  String?
  createdAt    DateTime @default(now())
}

model EventSubmission {
  id             String         @id @default(cuid())
  title          String
  description    String
  region         String
  format         EventFormat
  specialization String
  startsAt       DateTime
  endsAt         DateTime
  organizer      String
  contactEmail   String
  approvalStatus ApprovalStatus @default(PENDING)
  createdAt      DateTime       @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  name      String
  role      UserRole?
  segment   String?
  source    String?
  value     Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([name])
  @@index([role])
  @@index([createdAt])
}
