generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  DOCTOR
  STUDENT
  SCIENTIST
  PARTNER
}

enum EventFormat {
  ONLINE
  HYBRID
  IN_PERSON
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Article {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  summary        String
  content        String
  author         String
  source         String
  region         String?
  specialization String?
  publishedAt    DateTime
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@index([publishedAt])
  @@index([specialization])
}

model Event {
  id              String         @id @default(cuid())
  slug            String         @unique
  title           String
  description     String
  region          String
  format          EventFormat
  specialization  String
  startsAt        DateTime
  endsAt          DateTime
  timezone        String         @default("Europe/Prague")
  organizer       String
  venue           String?
  registrationUrl String?
  approvalStatus  ApprovalStatus @default(APPROVED)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([startsAt])
  @@index([region])
  @@index([format])
  @@index([specialization])
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  role        UserRole
  preferences Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactSubmission {
  id           String   @id @default(cuid())
  name         String
  email        String
  organization String?
  role         UserRole?
  topic        String
  message      String
  targetEmail  String
  leadSource   String?
  leadQuality  String?
  createdAt    DateTime @default(now())
}

model EventSubmission {
  id             String         @id @default(cuid())
  title          String
  description    String
  region         String
  format         EventFormat
  specialization String
  startsAt       DateTime
  endsAt         DateTime
  organizer      String
  contactEmail   String
  approvalStatus ApprovalStatus @default(PENDING)
  createdAt      DateTime       @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  name      String
  role      UserRole?
  segment   String?
  source    String?
  value     Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([name])
  @@index([role])
  @@index([createdAt])
}
