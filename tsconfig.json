{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "node_modules.bak",
    "supabase/functions",
    "tests",
    "e2e",
    ".deploy-tmp",
    ".build-tmp",
    ".tools",
    "src",
    "repo-temp",
    "github-production",
    "vitest.config.ts",
    "playwright.config.ts",
    "prisma.config.ts",
    "sentry.client.config.ts",
    "sentry.server.config.ts"
  ]
}

