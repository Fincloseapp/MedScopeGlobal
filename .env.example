# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — auto DDL (npm run db:apply-pg or db:setup)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres
# SUPABASE_ACCESS_TOKEN=from https://supabase.com/dashboard/account/tokens
# SUPABASE_PROJECT_REF=your-project-ref

# Site URL (production canonical + OG)
NEXT_PUBLIC_SITE_URL=https://medscopeglobal.com

# Default language for ingested articles (cs | en)
INGESTION_LOCALE=cs
DEFAULT_SITE_LOCALE=cs

# Stripe (live keys in .env.local only — never commit)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Admin notifications (ad campaigns)
ADMIN_NOTIFY_EMAIL=dawe.zegzul@seznam.cz

# V5 — Groq (FREE, primary when set) — gsk_… from https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=llama3-70b-8192
GROQ_MODEL_FALLBACK=mixtral-8x7b-32768
GROQ_MODEL_FALLBACK_2=gemma2-9b-it

# AI article ingestion (OpenAI — optional fallback #4)
# Must start with sk- (from https://platform.openai.com/api-keys). Do NOT paste Google/Gemini keys here.
OPENAI_API_KEY=

# Google AI Studio / Gemini (optional fallback #3) — AIza… or AQ.… from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# PubMed E-utilities (reduces 429 rate limits)
NCBI_CONTACT_EMAIL=info@medscopeglobal.com
NCBI_TOOL=medscopeglobal
# NCBI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Cron: GET /api/cron/ingest?secret=... or Authorization: Bearer ...
CRON_SECRET=generate-a-long-random-string

# Cloudflare Turnstile (anti-bot)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Security — AI keys server-side only (never NEXT_PUBLIC_)
# OPENAI_API_KEY is already above

# Vercel deploy (scripts/deploy-vercel-production.mjs)
# GITHUB_TOKEN=github_pat_...   # push → Fincloseapp/MedScopeGlobal → auto Vercel
# VERCEL_TOKEN=                 # optional: env sync + redeploy hook
# VERCEL_PROJECT_ID=prj_xewXFpK1L2PYN9kaqPrilPluQOEj
# VERCEL_ORG_ID=team_m1FSjvKjWV9Wgm1WhEycgHqJ

# Optional: fixed author UUID for ingested articles (defaults to first admin)
# INGESTION_AUTHOR_ID=
