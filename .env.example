# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — auto DDL (npm run db:apply-pg or db:setup)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres
# SUPABASE_ACCESS_TOKEN=from https://supabase.com/dashboard/account/tokens
# SUPABASE_PROJECT_REF=your-project-ref

# Site URL (production canonical + OG)
NEXT_PUBLIC_SITE_URL=https://medscopeglobal.com

# Default language for ingested articles (cs | en)
INGESTION_LOCALE=cs
DEFAULT_SITE_LOCALE=cs

# Stripe (live keys in .env.local only — never commit)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Admin notifications (ad campaigns)
ADMIN_NOTIFY_EMAIL=dawe.zegzul@seznam.cz

# AI article ingestion (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Cron: GET /api/cron/ingest?secret=... or Authorization: Bearer ...
CRON_SECRET=generate-a-long-random-string

# Cloudflare Turnstile (anti-bot)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Security — AI keys server-side only (never NEXT_PUBLIC_)
# OPENAI_API_KEY is already above

# Vercel deploy (scripts/deploy-vercel-production.mjs)
# GITHUB_TOKEN=github_pat_...   # push → Fincloseapp/MedScopeGlobal → auto Vercel
# VERCEL_TOKEN=                 # optional: env sync + redeploy hook
# VERCEL_PROJECT_ID=prj_xewXFpK1L2PYN9kaqPrilPluQOEj
# VERCEL_ORG_ID=team_m1FSjvKjWV9Wgm1WhEycgHqJ

# Optional: fixed author UUID for ingested articles (defaults to first admin)
# INGESTION_AUTHOR_ID=
