# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — auto DDL (npm run db:apply-pg or db:setup)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres
# SUPABASE_ACCESS_TOKEN=from https://supabase.com/dashboard/account/tokens
# SUPABASE_PROJECT_REF=your-project-ref

# Site URL (production canonical + OG)
NEXT_PUBLIC_SITE_URL=https://medscopeglobal.com

# Default language for ingested articles (cs | en)
INGESTION_LOCALE=cs
DEFAULT_SITE_LOCALE=cs

# Stripe (live keys in .env.local only — never commit)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Admin notifications (ad campaigns)
ADMIN_NOTIFY_EMAIL=dawe.zegzul@seznam.cz

# Admin gate (/admin/login) — plain text, synced to Vercel via npm run vercel:env
ADMIN_GATE_PASSWORD=your-admin-password

# V5 — Groq (FREE, primary when set) — gsk_… from https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant
GROQ_MODEL_FALLBACK_2=openai/gpt-oss-20b

# AI article ingestion (OpenAI — optional fallback #4)
# Must start with sk- (from https://platform.openai.com/api-keys). Do NOT paste Google/Gemini keys here.
OPENAI_API_KEY=

# Google AI Studio / Gemini (optional fallback #3) — AIza… or AQ.… from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# PubMed E-utilities (reduces 429 rate limits)
NCBI_CONTACT_EMAIL=info@medscopeglobal.com
NCBI_TOOL=medscopeglobal
# NCBI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Cron: GET /api/cron/ingest?secret=... or Authorization: Bearer ...
CRON_SECRET=generate-a-long-random-string

# Academy AI video — HeyGen (preferred) or Synthesia
# HEYGEN_API_KEY=from https://app.heygen.com/settings?nav=API
# HEYGEN_AVATAR_ID=
# HEYGEN_VOICE_ID=
# SYNTHESIA_API_KEY=from https://app.synthesia.io/#/account/api
# SYNTHESIA_AVATAR_ID=
# VIDEO_WEBHOOK_SECRET=shared secret for /api/academy/video/webhook

# Academy expert review cron (weekly) — auto-publish approved drafts
# ACADEMY_EXPERT_REVIEW_AUTO_PUBLISH=true

# SendGrid — primary email (v28 engine + Academy digest)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@medscopeglobal.com
# Optional: SendGrid Marketing list ID for bulk digest
SENDGRID_ACADEMY_LIST_ID=
# Fallback single recipient when no list ID
ACADEMY_NEWSLETTER_TO=
# Optional: SendGrid Event Webhook auth
SENDGRID_WEBHOOK_SECRET=

# SMTP fallback (v28 engine — used when SendGrid fails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_SECURE=false

# AI newsletter segments (optional list IDs or single TO)
NEWSLETTER_PUBLIC_LIST=
NEWSLETTER_PUBLIC_TO=
NEWSLETTER_STUDENTS_LIST=
NEWSLETTER_STUDENTS_TO=
NEWSLETTER_DOCTORS_LIST=
NEWSLETTER_DOCTORS_TO=

# Cloudflare Turnstile (anti-bot)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Security — AI keys server-side only (never NEXT_PUBLIC_)
# OPENAI_API_KEY is already above

# Vercel deploy (scripts/deploy-vercel-production.mjs)
# GITHUB_TOKEN=github_pat_...   # push → Fincloseapp/MedScopeGlobal → auto Vercel
# VERCEL_TOKEN=                 # optional: env sync + redeploy hook
# VERCEL_PROJECT_ID=prj_xewXFpK1L2PYN9kaqPrilPluQOEj
# VERCEL_ORG_ID=team_m1FSjvKjWV9Wgm1WhEycgHqJ

# Optional: fixed author UUID for ingested articles (defaults to first admin)
# INGESTION_AUTHOR_ID=
